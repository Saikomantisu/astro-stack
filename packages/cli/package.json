{
  "name": "create-astro-stack",
  "version": "0.1.1",
  "description": "Create a production-ready Astro project with a guided setup.",
  "license": "MIT",
  "author": "Ravinath Akalanka",
  "homepage": "https://github.com/Saikomantisu/astro-stack#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Saikomantisu/astro-stack.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/Saikomantisu/astro-stack/issues"
  },
  "keywords": [
    "astro",
    "create-astro",
    "starter",
    "scaffolding",
    "cli"
  ],
  "type": "module",
  "engines": {
    "node": ">=22.13"
  },
  "bin": {
    "astro-stack": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist",
    "dev": "pnpm run build && pnpm run start",
    "start": "cd ../.. && node packages/cli/dist/index.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@astro-stack/generator": "workspace:*",
    "@astro-stack/utils": "workspace:*",
    "@clack/prompts": "^1.7.0",
    "commander": "^15.0.0"
  }
}
