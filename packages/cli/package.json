{
  "name": "@astro-stack/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "astro-stack": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist",
    "dev": "pnpm run build && pnpm run start",
    "start": "cd ../.. && node packages/cli/dist/index.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@astro-stack/generator": "workspace:*",
    "@astro-stack/utils": "workspace:*",
    "@clack/prompts": "^1.7.0",
    "commander": "^15.0.0"
  }
}
