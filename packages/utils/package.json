{
  "name": "@astro-stack/utils",
  "version": "0.1.1",
  "description": "Shared configuration types and utilities for Astro Stack.",
  "license": "MIT",
  "author": "Ravinath Akalanka",
  "homepage": "https://github.com/Saikomantisu/astro-stack#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Saikomantisu/astro-stack.git",
    "directory": "packages/utils"
  },
  "bugs": {
    "url": "https://github.com/Saikomantisu/astro-stack/issues"
  },
  "keywords": [
    "astro",
    "utilities",
    "configuration"
  ],
  "type": "module",
  "engines": {
    "node": ">=22.13"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  }
}
