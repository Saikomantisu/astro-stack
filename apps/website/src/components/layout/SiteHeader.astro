---
import BrandGithub from "@tabler/icons/outline/brand-github.svg";
import BaseLink from "@/components/common/BaseLink.astro";
import Container from "@/components/common/Container.astro";
import Wordmark from "@/components/common/Wordmark.astro";
import MobileNav from "@/components/layout/MobileNav.astro";
import { Button } from "@/components/starwind/button";
import { withBase } from "@/lib/paths";
import { cta, links, primaryNav } from "@/lib/site";

const ctaHref = withBase(cta.href);
---

<header
  class="border-border/60 bg-background/80 supports-backdrop-filter:bg-background/70 sticky top-0 z-40 border-b backdrop-blur-md"
>
  <Container class="flex h-16 items-center justify-between gap-4">
    <Wordmark />

    <nav class="hidden items-center gap-1 md:flex" aria-label="Primary">
      {
        primaryNav.map((item) => (
          <BaseLink
            href={item.href}
            class="text-muted-foreground hover:text-foreground focus-visible:ring-outline/50 rounded-md px-3 py-2 text-sm font-medium transition-colors outline-none focus-visible:ring-3"
          >
            {item.label}
          </BaseLink>
        ))
      }
      <BaseLink
        href={links.docs}
        class="text-muted-foreground hover:text-foreground focus-visible:ring-outline/50 rounded-md px-3 py-2 text-sm font-medium transition-colors outline-none focus-visible:ring-3"
      >
        Documentation
      </BaseLink>
      <BaseLink
        href="changelog/"
        class="text-muted-foreground hover:text-foreground focus-visible:ring-outline/50 rounded-md px-3 py-2 text-sm font-medium transition-colors outline-none focus-visible:ring-3"
      >
        Changelog
      </BaseLink>
    </nav>

    <div class="flex items-center gap-2">
      <Button
        href={links.github}
        variant="ghost"
        size="icon-sm"
        class="hidden md:inline-flex"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="View Astro Stack on GitHub"
        title="View on GitHub"
      >
        <BrandGithub aria-hidden="true" />
      </Button>
      <Button
        href={ctaHref}
        variant="primary"
        size="sm"
        class="hidden md:inline-flex"
      >
        {cta.label}
      </Button>
      <MobileNav />
    </div>
  </Container>
</header>
