---
interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<div
  class:list={[
    "prose-site max-w-none space-y-4 text-base leading-relaxed",
    "[&_h2]:font-display [&_h2]:mt-10 [&_h2]:mb-3 [&_h2]:text-2xl [&_h2]:tracking-tight [&_h2]:first:mt-0",
    "[&_h3]:font-display [&_h3]:mt-8 [&_h3]:mb-2 [&_h3]:text-xl [&_h3]:tracking-tight",
    "[&_p]:text-muted-foreground [&_p]:leading-relaxed",
    "[&_ul]:text-muted-foreground [&_ul]:list-disc [&_ul]:space-y-2 [&_ul]:pl-5",
    "[&_ol]:text-muted-foreground [&_ol]:list-decimal [&_ol]:space-y-2 [&_ol]:pl-5",
    "[&_li]:leading-relaxed",
    "[&_a]:text-primary [&_a]:underline-offset-4 hover:[&_a]:underline",
    "[&_strong]:text-foreground [&_strong]:font-semibold",
    "[&_code]:text-info [&_code]:bg-muted [&_code]:rounded [&_code]:px-1.5 [&_code]:py-0.5 [&_code]:text-sm",
    "[&_pre]:border-border [&_pre]:bg-muted/50 [&_pre]:overflow-x-auto [&_pre]:rounded-lg [&_pre]:border [&_pre]:p-4 [&_pre]:text-sm",
    "[&_hr]:border-border [&_hr]:my-8",
    className,
  ]}
>
  <slot />
</div>
