---
import Section from "@/components/common/Section.astro";
import { Badge } from "@/components/starwind/badge";
import { projectTypes, projectTypesSection } from "@/lib/content/project-types";
---

<Section id={projectTypesSection.id} compact aria-labelledby="project-types-heading">
  <div class="mx-auto mb-10 max-w-2xl text-center">
    <p class="text-peach mb-3 text-sm font-medium tracking-wide uppercase">
      <span aria-hidden="true">✦</span>
      {" "}
      {projectTypesSection.eyebrow}
    </p>
    <h2
      id="project-types-heading"
      class="font-display text-3xl tracking-tight text-balance sm:text-4xl"
    >
      {projectTypesSection.title}
    </h2>
    <p class="text-muted-foreground mt-4 text-lg leading-relaxed">
      {projectTypesSection.description}
    </p>
  </div>

  <ul class="flex flex-wrap items-center justify-center gap-2.5" role="list">
    {
      projectTypes.map((type) => (
        <li>
          <Badge variant="outline" class="px-3.5 py-1.5 text-sm">
            {type}
          </Badge>
        </li>
      ))
    }
  </ul>
</Section>
