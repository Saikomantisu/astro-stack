---
interface Props {
  title?: string;
}
const { title = "Important" } = Astro.props;
---
<aside class="border-warning/35 bg-warning/10 my-6 rounded-xl border p-4" aria-label={title}>
  <p class="text-warning mb-1 text-sm font-bold tracking-wide">{title}</p>
  <div class="text-muted-foreground text-sm leading-relaxed"><slot /></div>
</aside>
