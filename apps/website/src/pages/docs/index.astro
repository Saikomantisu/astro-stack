---
import { getEntry, render } from "astro:content";
import DocsLayout from "@/layouts/DocsLayout.astro";

const entry = await getEntry("docs", "index");
if (!entry) throw new Error("Documentation introduction content is missing.");
const { Content, headings } = await render(entry);
---

<DocsLayout title={entry.data.title} description={entry.data.description} slug="" headings={headings}>
  <Content />
</DocsLayout>
