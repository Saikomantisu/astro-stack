---
import Container from "@/components/common/Container.astro";
import SiteFooter from "@/components/layout/SiteFooter.astro";
import SiteHeader from "@/components/layout/SiteHeader.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { site as siteConfig } from "@/lib/site";

interface Props {
  title: string;
  description?: string;
  /** Optional eyebrow above the page title. */
  eyebrow?: string;
}

const { title, description = siteConfig.description, eyebrow } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <SiteHeader />
  <main id="main-content" class="flex-1">
    <Container class="py-12 sm:py-16">
      <header class="mb-10 max-w-2xl space-y-3">
        {
          eyebrow && (
            <p class="text-peach text-sm font-medium tracking-wide uppercase">
              <span aria-hidden="true">✦</span> {eyebrow}
            </p>
          )
        }
        <h1 class="font-display text-3xl tracking-tight text-balance sm:text-4xl">{title}</h1>
        {
          description && (
            <p class="text-muted-foreground text-lg leading-relaxed">{description}</p>
          )
        }
      </header>
      <div class="max-w-3xl">
        <slot />
      </div>
    </Container>
  </main>
  <SiteFooter />
</BaseLayout>
