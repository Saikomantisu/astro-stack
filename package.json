{
  "name": "astro-stack",
  "version": "0.1.0",
  "private": true,
  "description": "Production-ready Astro project generator.",
  "license": "MIT",
  "author": "Ravinath Akalanka",
  "homepage": "https://github.com/Saikomantisu/astro-stack#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Saikomantisu/astro-stack.git"
  },
  "bugs": {
    "url": "https://github.com/Saikomantisu/astro-stack/issues"
  },
  "engines": {
    "node": ">=22.13"
  },
  "packageManager": "pnpm@11.0.8",
  "scripts": {
    "build": "pnpm --recursive run build",
    "check": "pnpm --recursive run check",
    "clean": "pnpm --recursive run clean",
    "lint": "biome lint .",
    "format": "biome format . --write",
    "format:check": "biome format .",
    "check:biome": "biome check .",
    "test": "vitest run --passWithNoTests",
    "test:generated": "ASTRO_STACK_RUN_GENERATED_TESTS=1 vitest run packages/generator/src/generated-projects.test.ts",
    "test:watch": "vitest",
    "changeset": "changeset",
    "version:packages": "changeset version && node scripts/update-release-changelog.mjs",
    "release:publish": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@changesets/cli": "^2.31.0",
    "@types/node": "^22.15.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
